# Ubuntu local development Compose environment example.
# Copy this to a local ignored env file and fill secrets before use.

COMPOSE_PROJECT_NAME=timelapse-ubuntu

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
CRED_ENC_KEY=
SESSION_HTTPS_ONLY=0

# Relative paths are resolved from the Compose project directory.
TIMELAPSE_DATA_DIR=./.timelapse-data
WEB_PORT=8080
WORKER_REST_PORT=8081
WORKER_GATEWAY_PORT=8082
WORKER_GRPC_PORT=50051

WEB_CONTAINER_NAME=timelapse-ubuntu-web
WORKER_CONTAINER_NAME=timelapse-ubuntu-worker
WORKER_GRPC_CONTAINER_NAME=timelapse-ubuntu-worker-grpc
WORKER_GATEWAY_CONTAINER_NAME=timelapse-ubuntu-worker-gateway

WORKER_BASE_URL=http://worker-gateway:8082
WORKER_GRPC_ADDR=worker-grpc:50051
WORKER_REST_URL=http://worker:8081
PLAYWRIGHT_APP_HOST=http://timelapse:8080

FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0
