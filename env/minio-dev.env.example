# Phase 5.0 Ubuntu-local MinIO only.
# Copy to .env.minio-dev and replace every credential before starting MinIO.

COMPOSE_PROJECT_NAME=timelapse-minio-dev
MINIO_CONTAINER_NAME=timelapse-minio-dev
MINIO_DATA_DIR=./.minio-data-dev
MINIO_VERIFY_DIR=./.minio-verify
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# MinIO server administrator credentials used only during bucket bootstrap.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bucket-scoped development uploader credentials used for round-trip verification.
MINIO_UPLOADER_ACCESS_KEY=
MINIO_UPLOADER_SECRET_KEY=
