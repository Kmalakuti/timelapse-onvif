# Windows edge side for Phase 4 split-host testing.
# Copy to .env.split-worker on Windows, fill secrets, and run with
# docker-compose.split-windows-worker.yml.

COMPOSE_PROJECT_NAME=timelapse-split-worker

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
# Use the production CRED_ENC_KEY only when using a copied production database.
CRED_ENC_KEY=
SESSION_HTTPS_ONLY=0

# Safe side-by-side defaults. Do not point split test at C:/timelapse-data.
TIMELAPSE_DATA_DIR=C:/timelapse-data-dev
WORKER_REST_PORT=18081
WORKER_GRPC_PORT=15051

WORKER_CONTAINER_NAME=timelapse-split-worker
WORKER_GRPC_CONTAINER_NAME=timelapse-split-worker-grpc

FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0

# Phase 5.2 uploader sidecar. Use the Ubuntu trusted-LAN MinIO API address only.
UPLOADER_CONTAINER_NAME=timelapse-split-uploader
STORAGE_S3_ENDPOINT_URL=http://10.20.30.188:19000
STORAGE_S3_BUCKET=timelapse-dev
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_TIMEOUT_SECONDS=3
UPLOADER_ORG_ID=org_dev_001
UPLOADER_SITE_ID=site_dev_001
UPLOADER_EDGE_ID=edge_dev_windows_001
# Optional JSON mapping from capture directory name to stable camera ID.
UPLOADER_CAMERA_IDS_JSON={}
UPLOADER_COMPLETION_GRACE_SECONDS=5
UPLOADER_SCAN_INTERVAL_SECONDS=5
UPLOADER_CONCURRENCY=2
UPLOADER_RETRY_MIN_SECONDS=2
UPLOADER_RETRY_MAX_SECONDS=300
UPLOADER_THUMB_MAX_DIMENSION=480
UPLOADER_THUMB_QUALITY=80
UPLOADER_PREVIEW_ENABLED=0
UPLOADER_PREVIEW_MAX_DIMENSION=1280
UPLOADER_PREVIEW_QUALITY=85
# Zero disables pacing. Set bytes per second to cap average upload throughput.
UPLOADER_BANDWIDTH_BYTES_PER_SECOND=0

# Phase 5.3 metadata publication to the Ubuntu core boundary.
UPLOADER_METADATA_INGEST_URL=http://10.20.30.188:18080/api/storage/frames
UPLOADER_METADATA_INGEST_TOKEN=
