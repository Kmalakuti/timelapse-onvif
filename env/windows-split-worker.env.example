# Windows edge side for Phase 4 split-host testing.
# Copy to .env.split-worker on Windows, fill secrets, and run with
# docker-compose.split-windows-worker.yml.

COMPOSE_PROJECT_NAME=timelapse-split-worker

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
# Use the production CRED_ENC_KEY only when using a copied production database.
CRED_ENC_KEY=
SESSION_HTTPS_ONLY=0

# Safe side-by-side defaults. Do not point split test at C:/timelapse-data.
TIMELAPSE_DATA_DIR=C:/timelapse-data-dev
WORKER_REST_PORT=18081
WORKER_GRPC_PORT=15051

WORKER_CONTAINER_NAME=timelapse-split-worker
WORKER_GRPC_CONTAINER_NAME=timelapse-split-worker-grpc

FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0
