# Windows side-by-side dev Compose environment example.
# Copy this to .env.dev-windows, fill secrets, and run with docker-compose.dev.yml.

COMPOSE_PROJECT_NAME=timelapse-dev

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
# Use the production CRED_ENC_KEY only when using a copied production database.
CRED_ENC_KEY=
SESSION_HTTPS_ONLY=0

# Safe side-by-side defaults. Do not point dev at C:/timelapse-data.
TIMELAPSE_DATA_DIR=C:/timelapse-data-dev
WEB_PORT=18080
WORKER_REST_PORT=18081
WORKER_GATEWAY_PORT=18082
WORKER_GRPC_PORT=15051

WEB_CONTAINER_NAME=timelapse-clean-web
WORKER_CONTAINER_NAME=timelapse-clean-worker
WORKER_GRPC_CONTAINER_NAME=timelapse-clean-worker-grpc
WORKER_GATEWAY_CONTAINER_NAME=timelapse-clean-worker-gateway

WORKER_BASE_URL=http://worker-gateway:8082
WORKER_GRPC_ADDR=worker-grpc:50051
WORKER_REST_URL=http://worker:8081
PLAYWRIGHT_APP_HOST=http://timelapse:8080

FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0
