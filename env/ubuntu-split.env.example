# Ubuntu app side for Phase 4 split-host testing.
# Copy to a local ignored env file and fill secrets before use.

COMPOSE_PROJECT_NAME=timelapse-split-ubuntu

# Phase 5.0 prototype resource IDs. Keep object keys stable as storage work proceeds.
PROTOTYPE_ORG_ID=org_dev_001
PROTOTYPE_SITE_ID=site_dev_001
PROTOTYPE_EDGE_ID=edge_windows_dev_001

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
CRED_ENC_KEY=
SESSION_HTTPS_ONLY=0

# Ubuntu-local app state. Do not mount SQLite over SMB/NFS.
TIMELAPSE_DATA_DIR=./.timelapse-data-split
WEB_PORT=18080
WORKER_GATEWAY_PORT=18082

WEB_CONTAINER_NAME=timelapse-split-web
WORKER_GATEWAY_CONTAINER_NAME=timelapse-split-worker-gateway

# Windows edge worker target. Update if the Windows host changes.
WINDOWS_EDGE_HOST=10.20.30.141
WORKER_BASE_URL=http://host.docker.internal:18082
WORKER_GRPC_ADDR=10.20.30.141:15051
WORKER_REST_URL=http://10.20.30.141:18081

# Ubuntu cannot reach the camera subnet in split mode.
USE_SNAPSHOT_THUMBS=0
PLAYWRIGHT_APP_HOST=http://timelapse:8080

# Phase 5.1 storage adapter. HTTP remains the default latest-frame path and
# explicit fallback while S3 comparison is isolated on Ubuntu-local MinIO.
LATEST_FRAME_SOURCE=http
LATEST_FRAME_HTTP_FALLBACK=1
STORAGE_BACKEND=filesystem
STORAGE_FILESYSTEM_ROOT=/data/_storage
STORAGE_S3_ENDPOINT_URL=http://10.20.30.188:19000
STORAGE_S3_BUCKET=timelapse-dev
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_TIMEOUT_SECONDS=3

FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0

# Phase 5.3 core-owned mapping and dev-only metadata ingest token.
# Keep this mapping aligned with the stable IDs used by the uploader.
CORE_CAMERA_IDS_JSON={}
METADATA_INGEST_TOKEN=
METADATA_MAX_FUTURE_SECONDS=300
TIMELINE_SOURCE=metadata
# Phase 5.4 cloud-only renderer comparison; filesystem remains the rollback value.
RENDER_SOURCE=storage
