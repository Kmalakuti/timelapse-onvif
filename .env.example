# Example environment for docker-compose.
# Copy to ".env" and fill in local values. Do not commit ".env" to git.
#
# Generate ADMIN_PASSWORD_HASH:
#   python -c "from app.auth import hash_password; print(hash_password('change-me'))"
#
# Generate SESSION_SECRET:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Generate CRED_ENC_KEY:
#   python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
CRED_ENC_KEY=

# Set to 1 when serving over HTTPS so cookies are marked secure.
SESSION_HTTPS_ONLY=0

# Docker Compose host settings. Defaults match the current Windows production stack.
TIMELAPSE_DATA_DIR=C:/timelapse-data
WEB_PORT=8080
WORKER_REST_PORT=8081
WORKER_GATEWAY_PORT=8082
WORKER_GRPC_PORT=50051

WEB_CONTAINER_NAME=timelapse-web
WORKER_CONTAINER_NAME=timelapse-worker
WORKER_GRPC_CONTAINER_NAME=timelapse-worker-grpc
WORKER_GATEWAY_CONTAINER_NAME=timelapse-worker-gateway

# Internal service endpoints. Change these only for split-host deployments.
WORKER_BASE_URL=http://worker-gateway:8082
WORKER_GRPC_ADDR=timelapse-worker-grpc:50051
WORKER_REST_URL=http://timelapse-worker:8081
PLAYWRIGHT_APP_HOST=http://timelapse-web:8080

# ffmpeg single-shot guard tuning (optional)
# margin = clamp(interval * ratio, min, max)
FFMPEG_GUARD_RATIO=0.20
FFMPEG_GUARD_MARGIN_MIN_SEC=4.0
FFMPEG_GUARD_MARGIN_MAX_SEC=25.0
